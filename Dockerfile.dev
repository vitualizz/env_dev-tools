FROM golang:1.24-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    git bash curl wget zsh sudo \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

# Build and run in CI mode by default
# Override with: docker compose run app ./vitualizz-devstack --tui
CMD ["bash", "-c", "go build -buildvcs=false -o /tmp/vitualizz-devstack ./cmd/vitualizz-devstack/ && /tmp/vitualizz-devstack --ci"]
