FROM golang:1.24-alpine

RUN apk add --no-cache git bash curl wget zsh sudo

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

# Build and run in CI mode by default
# Override with: docker compose run app ./envsetup --tui
CMD ["sh", "-c", "go build -buildvcs=false -o /tmp/vitualizz-devstack ./cmd/vitualizz-devstack/ && /tmp/vitualizz-devstack --ci"]
